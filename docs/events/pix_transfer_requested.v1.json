{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Defyland/pixrail-go-payment-switch/docs/events/pix_transfer_requested.v1.json",
  "title": "PixTransferRequested v1",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "occurred_at", "producer", "tenant_id", "account_id", "pix_transfer_id", "correlation_id", "payload"],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "const": "pix_transfer_requested" },
    "schema_version": { "type": "string", "const": "1" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "const": "pixrail.payment-switch" },
    "tenant_id": { "type": "string" },
    "account_id": { "type": "string" },
    "pix_transfer_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["amount_cents", "currency", "receiver_key_type"],
      "properties": {
        "amount_cents": { "type": "integer", "minimum": 1 },
        "currency": { "type": "string", "const": "BRL" },
        "receiver_key_type": { "type": "string", "enum": ["CPF", "CNPJ", "EMAIL", "PHONE", "EVP"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
