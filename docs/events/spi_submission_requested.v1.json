{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Defyland/pixrail-go-payment-switch/docs/events/spi_submission_requested.v1.json",
  "title": "SPISubmissionRequested v1",
  "type": "object",
  "required": ["event_id", "event_type", "schema_version", "occurred_at", "producer", "tenant_id", "account_id", "pix_transfer_id", "correlation_id", "payload"],
  "properties": {
    "event_id": { "type": "string" },
    "event_type": { "type": "string", "const": "spi_submission_requested" },
    "schema_version": { "type": "string", "const": "1" },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "const": "pixrail.payment-switch" },
    "tenant_id": { "type": "string" },
    "account_id": { "type": "string" },
    "pix_transfer_id": { "type": "string" },
    "correlation_id": { "type": "string" },
    "payload": {
      "type": "object",
      "required": ["request_hash"],
      "properties": {
        "request_hash": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
